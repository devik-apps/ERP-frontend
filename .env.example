# Variables d'environnement — copier vers .env pour surcharger les valeurs par défaut.
# Le fichier .env est ignoré par git (cf. .gitignore).

# URL de base de l'API ERP (exposée côté client via runtimeConfig.public.apiBase).
# Fallback dans nuxt.config.ts : https://api.erp.local/v1
NUXT_PUBLIC_API_BASE=https://api.erp.local/v1
