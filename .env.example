# Variables d'environnement — copier vers .env pour surcharger les valeurs par défaut.
# Le fichier .env est ignoré par git (cf. .gitignore).

# URL de base appelée par le client.
# - mettre `/api/v1` pour passer par le proxy Nitro (recommandé, évite CORS).
# - mettre l'URL absolue du backend si le backend gère bien le CORS.
# Fallback dans nuxt.config.ts : https://api.erp.local/v1
NUXT_PUBLIC_API_BASE=/api/v1

# Cible réelle du backend, utilisée par le proxy Nitro `server/api/v1/[...].ts`.
# Serveur uniquement — jamais exposée au navigateur.
ERP_BACKEND_URL=https://api.erp.local/v1
