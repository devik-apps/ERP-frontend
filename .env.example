# Variables d'environnement — copier vers .env pour surcharger les valeurs par défaut.
# Le fichier .env est ignoré par git (cf. .gitignore).

# URL de base appelée par le client (same-origin pour éviter le CORS).
# Les requêtes sont relayées par le proxy Nitro `server/api/v1/[...].ts`
# vers `ERP_BACKEND_URL`.
NUXT_PUBLIC_API_BASE=/api/v1

# Cible réelle du backend (serveur uniquement, jamais exposée au navigateur).
ERP_BACKEND_URL=https://erp-backend-ex0d.onrender.com/api/v1

# Supabase Auth — projet dédié à l'ERP.
# `SUPABASE_URL` et `SUPABASE_KEY` (anon) sont lues par @nuxtjs/supabase.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...
